<Project Sdk="Aspire.AppHost.Sdk/13.2.1">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <UserSecretsId>nugetgallery-apphost-dev</UserSecretsId>

    <!-- The repo's Directory.Build.targets disables assembly version attributes
         (they're generated by CI build infrastructure). Re-enable for this dev-only project. -->
    <GenerateAssemblyFileVersionAttribute>true</GenerateAssemblyFileVersionAttribute>
    <GenerateAssemblyInformationalVersionAttribute>true</GenerateAssemblyInformationalVersionAttribute>
    <GenerateAssemblyVersionAttribute>true</GenerateAssemblyVersionAttribute>
  </PropertyGroup>

  <ItemGroup>
    <!-- V3 pipeline projects (SDK-style net472 — Aspire handles the TFM gap) -->
    <ProjectReference Include="..\Ng\Ng.csproj" />
    <ProjectReference Include="..\NuGet.Jobs.Catalog2Registration\NuGet.Jobs.Catalog2Registration.csproj" />
    <ProjectReference Include="..\NuGet.Jobs.Catalog2AzureSearch\NuGet.Jobs.Catalog2AzureSearch.csproj" />
    <ProjectReference Include="..\NuGet.Jobs.Db2AzureSearch\NuGet.Jobs.Db2AzureSearch.csproj" />
    <ProjectReference Include="..\NuGet.Jobs.Auxiliary2AzureSearch\NuGet.Jobs.Auxiliary2AzureSearch.csproj" />
    <ProjectReference Include="..\NuGet.Services.SearchService.Core\NuGet.Services.SearchService.Core.csproj" />
    <ProjectReference Include="..\NuGetGallery.AppHost.Config\NuGetGallery.AppHost.Config.csproj" IsAspireProjectResource="false" />
    <ProjectReference Include="..\NuGetGallery.AppHost.Tools\NuGetGallery.AppHost.Tools.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Aspire Azure integrations -->
    <PackageReference Include="Aspire.Hosting.Azure.Storage" />
    <PackageReference Include="Aspire.Hosting.Azure.Search" />

    <!-- Used by reset commands to clear search indexes and blob containers -->
    <PackageReference Include="Azure.Search.Documents" />

    <!-- Used by gallery reset command to drop databases -->
    <PackageReference Include="System.Data.SqlClient" />

    <!-- EF6 tools — GeneratePathProperty gives us $(PkgEntityFramework) at build time.
         ExcludeAssets="all" prevents EF6 DLLs from polluting the net10.0 AppHost. -->
    <PackageReference Include="EntityFramework" GeneratePathProperty="true" ExcludeAssets="all" />
  </ItemGroup>

  <!-- Build net472 projects (GalleryTools → NuGetGallery) with VS MSBuild.
       The .NET SDK cannot build legacy non-SDK projects like NuGetGallery.csproj,
       so we discover the VS MSBuild via vswhere.exe (same approach as build/common.ps1). -->
  <Target Name="BuildNet472Projects" BeforeTargets="Build"
          Condition="'$(BuildingInsideVisualStudio)' != 'true'">
    <PropertyGroup>
      <VsWhereExe>$([MSBuild]::NormalizePath('$(ProgramFiles)\Microsoft Visual Studio\Installer\vswhere.exe'))</VsWhereExe>
      <VsWhereExe Condition="!Exists('$(VsWhereExe)')">$([MSBuild]::NormalizePath('$(MSBuildProgramFiles32)\Microsoft Visual Studio\Installer\vswhere.exe'))</VsWhereExe>
    </PropertyGroup>
    <Error Text="vswhere.exe not found. Visual Studio is required to build net472 projects." Condition="!Exists('$(VsWhereExe)')" />
    <Exec Command="&quot;$(VsWhereExe)&quot; -latest -prerelease -property installationPath" ConsoleToMsBuild="true">
      <Output TaskParameter="ConsoleOutput" PropertyName="_VsInstallDir" />
    </Exec>
    <PropertyGroup>
      <_VsMSBuild>$(_VsInstallDir)\MSBuild\Current\bin\msbuild.exe</_VsMSBuild>
    </PropertyGroup>
    <Error Text="VS MSBuild not found at $(_VsMSBuild)" Condition="!Exists('$(_VsMSBuild)')" />
    <Exec Command="&quot;$(_VsMSBuild)&quot; &quot;$(MSBuildThisFileDirectory)..\GalleryTools\GalleryTools.csproj&quot; /t:Restore;Build /p:Configuration=$(Configuration) /v:minimal /nologo /m" />
  </Target>

  <!-- Generate a C# source file with the ef6.exe path baked in as a compile-time constant. -->
  <Target Name="GenerateEf6Paths" BeforeTargets="CoreCompile" DependsOnTargets="ResolvePackageAssets">
    <PropertyGroup>
      <_Ef6PathsContent>internal static class PackagePaths { internal const string Ef6ToolsDir = @"$(PkgEntityFramework)\tools\net45\any"%3B }</_Ef6PathsContent>
    </PropertyGroup>
    <WriteLinesToFile
      File="$(IntermediateOutputPath)PackagePaths.g.cs"
      Lines="$(_Ef6PathsContent)"
      Overwrite="true" />
    <ItemGroup>
      <Compile Include="$(IntermediateOutputPath)PackagePaths.g.cs" />
    </ItemGroup>
  </Target>

</Project>
