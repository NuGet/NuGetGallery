{
  "NuGetGallery": {
    "GalleryBaseAddress": "http://localhost",
    "SearchServiceBaseAddress": "http://127.0.0.1:5200",
    "GalleryDb": {
      "ConnectionString": "Data Source=(localdb)\\mssqllocaldb;Initial Catalog=NuGetGallery;Integrated Security=True;MultipleActiveResultSets=True"
    },

    "Containers": {
      "Catalog": "v3-catalog0",
      "FlatContainer": "v3-flatcontainer",
      "RegistrationSemVer1": "v3-registration5-semver1",
      "RegistrationGzSemVer1": "v3-registration5-gz-semver1",
      "RegistrationGzSemVer2": "v3-registration5-gz-semver2",
      "AzureSearch": "v3-azuresearch0",
      "ServiceIndex": "v3-index",
      "CdnStats": "nuget-cdnstats",
      "SearchAuxiliary": "search-auxiliary",
      "Packages": "packages",
      "Auditing": "auditing",
      "Content": "content",
      "Uploads": "uploads"
    },

    "SearchIndexes": {
      "Search": "search-index",
      "Hijack": "hijack-index"
    },

    "AuxiliaryBlobs": {
      "DownloadsV1Json": "downloads.v1.json",
      "ExcludedPackagesJson": "ExcludedPackages.v1.json",
      "FlagsJson": "flags.json"
    },

    "Scoring": {
      "FieldWeights": {
        "PackageId": 9.0,
        "TokenizedPackageId": 9.0,
        "Tags": 5.0
      },
      "DownloadScoreBoost": 30000.0,
      "PopularityTransfer": 0.99
    },

    "Settings": {
      "PollIntervalSeconds": 3,
      "CursorSize": 50,
      "MinPushPeriod": "00:00:10",
      "MaxDownloadCountDecreases": 30000,
      "EnablePopularityTransfers": true
    }
  }
}
